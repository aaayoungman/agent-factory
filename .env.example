# === Required: At least one provider API key ===
ANTHROPIC_API_KEY=sk-ant-...

# === Optional: Additional providers ===
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...

# === Optional: Embedding provider for memory vector search ===
# At least one is needed for semantic memory search (auto-detected)
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# === Optional: Force mode ===
# AGENT_FACTORY_MODE=auto|attached|standalone

# === Optional: Attached mode ===
# OPENCLAW_GATEWAY_TOKEN=your-token-here

# === Optional: Standalone mode overrides ===
# OPENCLAW_GATEWAY_PORT=19100
